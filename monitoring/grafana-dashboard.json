{
  "title": "HarborNet Monitoring Dashboard",
  "tags": ["HarborNet", "DevOps", "Monitoring"],

  "panels": [
    {
      "title": "Application Uptime",
      "type": "stat",
      "query": "up{job=\"harbornet-application\"}"
    },
    {
      "title": "Request Latency",
      "type": "graph",
      "query": "rate(http_request_duration_seconds_sum[5m])"
    },
    {
      "title": "Database Connections",
      "type": "gauge",
      "query": "sqlite_connections_count"
    }
  ]
}
